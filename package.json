{
  "name": "origin",
  "version": "0.1.0",
  "private": true,
  "description": "Origin \u2014 Chinese EV car rental platform for Dubai/UAE. Customer site, admin dashboard, and backend API.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "customer:dev": "npm run dev --workspace=customer",
    "customer:build": "npm run build --workspace=customer",
    "admin:dev": "npm run dev --workspace=admin",
    "admin:build": "npm run build --workspace=admin",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "backend:dev": "npm run dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maximumEffort/origin.git"
  },
  "license": "UNLICENSED"
}
