  completedAt  DateTime?       @map("completed_at") @db.Timestamp(3)
  odometerKm   Int             @map("odometer_km")
  costMinor    BigInt          @map("cost_minor")
  currencyCode String          @map("currency_code") @db.Char(3)
  vendor       String?
