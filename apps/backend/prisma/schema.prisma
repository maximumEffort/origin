generator client {
  // Python Prisma client. Same schema file as the Node backend so the database
  // stays the single source of truth during the migration window.
  // Docs: https://prisma-client-py.readthedocs.io/
  provider                   = "prisma-client-py"
  recursive_type_depth       = 5
  interface                  = "asyncio"
  partial_type_generator     = "prisma/partials.py"
  // Origin uses Decimal for currency fields (vehicle prices, payments, etc.).
  // Prisma Python requires opt-in for Decimal support.
  enable_experimental_decimal = "true"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Brand {
  BYD
  HAVAL
  GWM
  CHERY
  OMODA
  GEELY
  JAECOO
  NIO
  VOYAH
  ZEEKR
  DONGFENG
  BESTUNE
  HONGQI
  FORTING
  WEY
  GREAT_WALL
}

enum FuelType {
  ELECTRIC
  HYBRID
  PETROL
  DIESEL
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum VehicleStatus {
  AVAILABLE
  LEASED
  MAINTENANCE
  RETIRED
}

enum Language {
  en
  ar
  zh
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentType {
  EMIRATES_ID
  DRIVING_LICENCE
  VISA
  PASSPORT
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum OcrStatus {
  NOT_STARTED
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum LeaseType {
  SHORT_TERM
  LONG_TERM
}

enum ServiceType {
  SELL
  RENT
  LEASE
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  CONVERTED
}

enum LeaseStatus {
  ACTIVE
  COMPLETED
  TERMINATED_EARLY
  RENEWED
}

enum PaymentType {
  DEPOSIT
  MONTHLY
  PENALTY
  REFUND
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  REFUNDED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum PaymentGateway {
  CHECKOUT_COM
  PAYTABS
  TABBY
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  SENT
  DELIVERED
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  FLEET_MANAGER
  SALES
  FINANCE
}

enum CustomerType {
  INDIVIDUAL
  CORPORATE
}

enum CompanyRole {
  ADMIN
  DRIVER
  FINANCE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  OVERDUE
  VOID
}

enum LogLevel {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

model VehicleCategory {
  id       String    @id @default(uuid())
  nameEn   String
  nameAr   String
  nameZh   String
  icon     String?
  vehicles Vehicle[]

  @@map("vehicle_categories")
}

model Vehicle {
  id                    String          @id @default(uuid())
  vin                   String          @unique
  plateNumber           String          @unique
  brand                 Brand
  model                 String
  year                  Int
  categoryId            String
  category              VehicleCategory @relation(fields: [categoryId], references: [id])
  fuelType              FuelType
  transmission          Transmission    @default(AUTOMATIC)
  colour                String
  seats                 Int
  status                VehicleStatus   @default(AVAILABLE)
  priceAed              Decimal?        @db.Decimal(12, 2)
  dailyRateAed          Decimal         @db.Decimal(10, 2)
  monthlyRateAed        Decimal         @db.Decimal(10, 2)
  leaseMonthlyAed       Decimal?        @db.Decimal(10, 2)
  depositAmountAed      Decimal?        @db.Decimal(10, 2)
  downPaymentPct        Decimal         @db.Decimal(4, 2) @default(0.20)
  mileageLimitMonthly   Int             @default(3000)
  rtaRegistrationExpiry DateTime?
  insuranceExpiry       DateTime?
  lastServiceDate       DateTime?
  nextServiceDue        DateTime?
  notes                 String?
  images                VehicleImage[]
  bookings              Booking[]
  assignedBookings      Booking[]       @relation("AssignedVehicle")
  leases                Lease[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("vehicles")
}

model VehicleImage {
  id        String  @id @default(uuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([vehicleId])
  @@map("vehicle_images")
}

model Customer {
  id                  String            @id @default(uuid())
  phone               String            @unique
  email               String?
  fullName            String
  nationality         String?
  preferredLanguage   Language          @default(en)
  customerType        CustomerType      @default(INDIVIDUAL)
  kycStatus           KycStatus         @default(PENDING)
  kycRejectionReason  String?
  whatsappOptIn       Boolean           @default(false)
  documents           Document[]
  bookings            Booking[]
  leases              Lease[]
  payments            Payment[]
  invoices            Invoice[]
  companyEmployees    CompanyEmployee[]
  notifications       NotificationLog[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("customers")
}

model Document {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            DocumentType
  fileUrl         String
  expiryDate      DateTime?
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewer        AdminUser?     @relation(fields: [reviewedBy], references: [id])

  ocrStatus         OcrStatus @default(NOT_STARTED)
  ocrProvider       String?
  ocrModel          String?
  ocrFields         Json?
  ocrConfidence     Float?
  ocrRequestedAt    DateTime?
  ocrCompletedAt    DateTime?
  ocrFailureReason  String?
  reviewerOverrides Json?

  @@index([customerId])
  @@index([ocrStatus])
  @@map("documents")
}

model Booking {
  id                String        @id @default(uuid())
  reference         String        @unique
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?      @relation(fields: [vehicleId], references: [id])
  assignedVehicleId String?
  assignedVehicle   Vehicle?      @relation("AssignedVehicle", fields: [assignedVehicleId], references: [id])
  leaseType         LeaseType
  serviceType       ServiceType   @default(RENT)
  startDate         DateTime
  endDate           DateTime
  durationDays      Int
  mileagePackage    Int
  addOns            Json          @default("{}")
  quotedTotalAed    Decimal       @db.Decimal(10, 2)
  vatAmountAed      Decimal       @db.Decimal(10, 2)
  grandTotalAed     Decimal       @db.Decimal(10, 2)
  depositAmountAed  Decimal       @db.Decimal(10, 2)
  depositPaid       Boolean       @default(false)
  status            BookingStatus @default(DRAFT)
  rejectionReason   String?
  pickupLocation    String?
  dropoffLocation   String?
  notes             String?
  lease             Lease?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@map("bookings")
}

model Lease {
  id                  String      @id @default(uuid())
  reference           String      @unique
  bookingId           String      @unique
  booking             Booking     @relation(fields: [bookingId], references: [id])
  customerId          String
  customer            Customer    @relation(fields: [customerId], references: [id])
  vehicleId           String
  vehicle             Vehicle     @relation(fields: [vehicleId], references: [id])
  startDate           DateTime
  endDate             DateTime
  serviceType         ServiceType @default(RENT)
  monthlyRateAed      Decimal     @db.Decimal(10, 2)
  vatRate             Decimal     @db.Decimal(4, 4) @default(0.0500)
  mileageLimitMonthly Int
  downPaymentAed      Decimal?    @db.Decimal(10, 2)
  status              LeaseStatus @default(ACTIVE)
  renewalOfId         String?
  renewalOf           Lease?      @relation("LeaseRenewal", fields: [renewalOfId], references: [id])
  renewals            Lease[]     @relation("LeaseRenewal")
  agreementPdfUrl     String?
  notes               String?
  payments            Payment[]
  invoices            Invoice[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@map("leases")
}

model Payment {
  id               String          @id @default(uuid())
  leaseId          String
  lease            Lease           @relation(fields: [leaseId], references: [id])
  customerId       String
  customer         Customer        @relation(fields: [customerId], references: [id])
  type             PaymentType
  amountAed        Decimal         @db.Decimal(10, 2)
  vatAmountAed     Decimal         @db.Decimal(10, 2)
  totalAed         Decimal         @db.Decimal(10, 2)
  dueDate          DateTime
  paidAt           DateTime?
  status           PaymentStatus   @default(PENDING)
  paymentMethod    PaymentMethod?
  gateway          PaymentGateway?
  gatewayReference String?
  invoicePdfUrl    String?
  invoice          Invoice?
  createdAt        DateTime        @default(now())

  @@index([leaseId])
  @@index([customerId])
  @@map("payments")
}

model NotificationLog {
  id              String              @id @default(uuid())
  customerId      String
  customer        Customer            @relation(fields: [customerId], references: [id])
  channel         NotificationChannel
  template        String
  language        Language
  contentSnapshot String
  status          NotificationStatus  @default(SENT)
  sentAt          DateTime            @default(now())
  metadata        Json                @default("{}")

  @@index([customerId])
  @@map("notification_logs")
}

model AdminUser {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String
  fullName  String
  role      AdminRole   @default(SALES)
  isActive  Boolean     @default(true)
  documents Document[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("admin_users")
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_inquiries")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
  @@map("otp_codes")
}

// ── Corporate Accounts ─────────────────────────────────────────

model Company {
  id                 String            @id @default(uuid())
  name               String
  tradeLicenceNumber String?           @unique
  crNumber           String?
  vatTrn             String?
  address            String?
  city               String?           @default("Dubai")
  contactEmail       String?
  contactPhone       String?
  billingEmail       String?
  discountPct        Decimal           @db.Decimal(4, 2) @default(0.00)
  creditTermDays     Int               @default(0)
  isActive           Boolean           @default(true)
  employees          CompanyEmployee[]
  invoices           Invoice[]
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("companies")
}

model CompanyEmployee {
  id         String      @id @default(uuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  role       CompanyRole @default(DRIVER)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())

  @@unique([companyId, customerId])
  @@index([companyId])
  @@index([customerId])
  @@map("company_employees")
}

// ── Invoices ───────────────────────────────────────────────────

model Invoice {
  id              String            @id @default(uuid())
  invoiceNumber   String            @unique
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id])
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id])
  leaseId         String?
  lease           Lease?            @relation(fields: [leaseId], references: [id])
  paymentId       String?           @unique
  payment         Payment?          @relation(fields: [paymentId], references: [id])
  periodStart     DateTime?
  periodEnd       DateTime?
  subtotalAed     Decimal           @db.Decimal(10, 2)
  vatRate         Decimal           @db.Decimal(4, 4) @default(0.0500)
  vatAmountAed    Decimal           @db.Decimal(10, 2)
  totalAed        Decimal           @db.Decimal(10, 2)
  vatTrn          String?
  status          InvoiceStatus     @default(DRAFT)
  issuedAt        DateTime?
  dueDate         DateTime?
  paidAt          DateTime?
  pdfUrl          String?
  notes           String?
  lineItems       InvoiceLineItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([companyId])
  @@index([leaseId])
  @@map("invoices")
}

model InvoiceLineItem {
  id           String  @id @default(uuid())
  invoiceId    String
  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String
  quantity     Int     @default(1)
  unitPriceAed Decimal @db.Decimal(10, 2)
  totalAed     Decimal @db.Decimal(10, 2)
  sortOrder    Int     @default(0)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ── Audit & Error Logs ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  userType   String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?    @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ErrorLog {
  id         String   @id @default(uuid())
  level      LogLevel @default(ERROR)
  message    String
  stackTrace String?
  endpoint   String?
  method     String?
  statusCode Int?
  userId     String?
  requestId  String?
  metadata   Json?    @default("{}")
  createdAt  DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@index([endpoint])
  @@map("error_logs")
}
