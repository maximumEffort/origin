  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy    String?         @map("created_by")
  updatedBy    String?         @map("updated_by")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, startedAt])
  @@map("vehicle_maintenance_records")
}

// ─────────────────────────────────────────────────────────────────────
// services/communications
// ─────────────────────────────────────────────────────────────────────

model CommunicationLog {
  id                String                @id
  countryId         String?               @map("country_id")
  correlationId     String?               @map("correlation_id")
  partyId           String?               @map("party_id")
  kind              CommunicationKind
  purpose           CommunicationPurpose
  templateCode      String                @map("template_code")
  recipientEmail    String?               @map("recipient_email")
  recipientPhone    String?               @map("recipient_phone")
  subject           String?
  bodyPreview       String                @map("body_preview")
  provider          CommunicationProvider
  providerMessageId String?               @map("provider_message_id")
  status            CommunicationStatus   @default(QUEUED)
  suppressedReason  String?               @map("suppressed_reason")
  sentAt            DateTime?             @map("sent_at") @db.Timestamp(3)
  deliveredAt       DateTime?             @map("delivered_at") @db.Timestamp(3)
  failedAt          DateTime?             @map("failed_at") @db.Timestamp(3)
  errorMessage      String?               @map("error_message")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  country Country? @relation(fields: [countryId], references: [id])
  party   Party?   @relation(fields: [partyId], references: [id])

  @@index([templateCode, sentAt])
  @@index([partyId, sentAt])
  @@index([correlationId])
  @@map("communication_logs")
}

// ─────────────────────────────────────────────────────────────────────
// services/intelligence
// ─────────────────────────────────────────────────────────────────────

model OcrJob {
  id              String       @id
  kycDocumentId   String       @map("kyc_document_id")
  provider        OcrProvider
  model           String
  status          OcrJobStatus @default(QUEUED)
  output          Json         @default("{}")
  errorMessage    String?      @map("error_message")
  startedAt       DateTime?    @map("started_at") @db.Timestamp(3)
  completedAt     DateTime?    @map("completed_at") @db.Timestamp(3)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  kycDocument KycDocument @relation(fields: [kycDocumentId], references: [id], onDelete: Cascade)

  @@index([kycDocumentId])
  @@map("ocr_jobs")
}

// ─────────────────────────────────────────────────────────────────────
// core/messaging — outbox event bus
// ─────────────────────────────────────────────────────────────────────

model OutboxEvent {
  id              String            @id
  countryId       String?           @map("country_id")
  correlationId   String?           @map("correlation_id")
  eventType       String            @map("event_type")
  aggregateType   String            @map("aggregate_type")
  aggregateId     String            @map("aggregate_id")
  payload         Json
  status          OutboxEventStatus @default(PENDING)
  attempts        Int               @default(0)
  lastError       String?           @map("last_error")
  availableAt     DateTime          @default(now()) @map("available_at") @db.Timestamp(3)
  processedAt     DateTime?         @map("processed_at") @db.Timestamp(3)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(3)

  country Country? @relation(fields: [countryId], references: [id])

  @@index([status, availableAt])
  @@index([eventType])
  @@index([correlationId])
  @@map("outbox_events")
}

// ─────────────────────────────────────────────────────────────────────
// core/observability — append-only logs
// ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String     @id
  countryId   String?    @map("country_id")
  actorKind   ActorKind  @map("actor_kind")
  actorId     String?    @map("actor_id")
  action      String
  targetKind  String?    @map("target_kind")
  targetId    String?    @map("target_id")
  payload     Json       @default("{}")
  ipAddress   String?    @map("ip_address")
  userAgent   String?    @map("user_agent")
  requestId   String?    @map("request_id")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamp(3)

  country Country? @relation(fields: [countryId], references: [id])

  @@index([actorKind, actorId, createdAt])
  @@index([targetKind, targetId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model ErrorLog {
  id         String   @id
  countryId  String?  @map("country_id")
  requestId  String?  @map("request_id")
  statusCode Int      @map("status_code")
  route      String
  method     String
  message    String
  stack      String?
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(3)

  country Country? @relation(fields: [countryId], references: [id])

  @@index([createdAt])
  @@index([requestId])
  @@map("error_logs")
}
