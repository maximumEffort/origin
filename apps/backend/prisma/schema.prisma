  pdfBlobUrl      String   @map("pdf_blob_url")
  signedAt        DateTime @map("signed_at") @db.Timestamp(3)
  signedIp        String?  @map("signed_ip")
  signatureMethod String   @map("signature_method")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")

  country     Country     @relation(fields: [countryId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  lease       Lease       @relation(fields: [leaseId], references: [id])

  @@map("rental_agreements")
}

model TermsDocument {
  id              String   @id
  countryId       String   @map("country_id")
  legalEntityId   String   @map("legal_entity_id")
  kind            String // TOS, PRIVACY, RENTAL_AGREEMENT_TEMPLATE
  version         String
  contentMd       String   @map("content_md")
  effectiveFrom   DateTime @map("effective_from") @db.Date
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")

  country     Country     @relation(fields: [countryId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@unique([countryId, legalEntityId, kind, version])
  @@map("terms_documents")
}

// ─────────────────────────────────────────────────────────────────────
// products/rental
// ─────────────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id
  countryId             String        @map("country_id")
  reference             String        @unique
  partyId               String        @map("party_id")
  bookedByCustomerId    String        @map("booked_by_customer_id")
  vehicleId             String        @map("vehicle_id")
  status                BookingStatus @default(DRAFT)
  startDate             DateTime      @map("start_date") @db.Date
  endDate               DateTime      @map("end_date") @db.Date
  durationDays          Int           @map("duration_days")
  mileagePackageId      String?       @map("mileage_package_id")
  addOns                Json          @default("[]") @map("add_ons")
  pickupLocation        String?       @map("pickup_location")
  dropoffLocation       String?       @map("dropoff_location")
  notes                 String?
  currencyCode          String        @map("currency_code") @db.Char(3)
  subtotalMinor         BigInt        @map("subtotal_minor")
  vatMinor              BigInt        @map("vat_minor")
  depositMinor          BigInt        @map("deposit_minor")
  totalMinor            BigInt        @map("total_minor")
  submittedAt           DateTime?     @map("submitted_at") @db.Timestamp(3)
  confirmedAt           DateTime?     @map("confirmed_at") @db.Timestamp(3)
  cancelledAt           DateTime?     @map("cancelled_at") @db.Timestamp(3)
  expiredAt             DateTime?     @map("expired_at") @db.Timestamp(3)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy             String?       @map("created_by")
  updatedBy             String?       @map("updated_by")

  country         Country         @relation(fields: [countryId], references: [id])
  party           Party           @relation(fields: [partyId], references: [id])
  bookedBy        Customer        @relation("BookingBookedBy", fields: [bookedByCustomerId], references: [id])
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id])
  mileagePackage  MileagePackage? @relation(fields: [mileagePackageId], references: [id])
  lease           Lease?

  @@index([partyId, status])
  @@index([bookedByCustomerId, status])
  @@index([vehicleId, startDate, endDate])
  @@map("bookings")
}

model Lease {
  id                       String      @id
  countryId                String      @map("country_id")
  legalEntityId            String      @map("legal_entity_id")
  bookingId                String      @unique @map("booking_id")
  partyId                  String      @map("party_id")
  primaryDriverCustomerId  String      @map("primary_driver_customer_id")
  vehicleId                String      @map("vehicle_id")
  leaseType                LeaseType   @map("lease_type")
  status                   LeaseStatus @default(ACTIVE)
  startDate                DateTime    @map("start_date") @db.Date
  endDate                  DateTime    @map("end_date") @db.Date
  actualEndDate            DateTime?   @map("actual_end_date") @db.Date
  currencyCode             String      @map("currency_code") @db.Char(3)
  monthlyRateMinor         BigInt      @map("monthly_rate_minor")
  dailyRateMinor           BigInt      @map("daily_rate_minor")
  depositHeldMinor         BigInt      @map("deposit_held_minor")
  depositRefundedMinor     BigInt      @default(0) @map("deposit_refunded_minor")
  includedKmPerMonth       Int         @map("included_km_per_month")
  overageRatePerKmMinor    BigInt      @map("overage_rate_per_km_minor")
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt                DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy                String?     @map("created_by")
  updatedBy                String?     @map("updated_by")

  country         Country         @relation(fields: [countryId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  booking         Booking         @relation(fields: [bookingId], references: [id])
  party           Party           @relation(fields: [partyId], references: [id])
  primaryDriver   Customer        @relation("LeasePrimaryDriver", fields: [primaryDriverCustomerId], references: [id])
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id])
  invoices        Invoice[]
  payments        Payment[]
  milestones      LeaseMilestone[]
  mileageReadings MileageReading[]
  agreement       RentalAgreement?

  @@index([partyId, status])
  @@index([primaryDriverCustomerId, status])
  @@index([vehicleId, status])
  @@map("leases")
}

model LeaseMilestone {
  id          String        @id
  leaseId     String        @map("lease_id")
  kind        MilestoneKind
  dueAt       DateTime      @map("due_at") @db.Timestamp(3)
  completedAt DateTime?     @map("completed_at") @db.Timestamp(3)
  payload     Json          @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId, kind])
  @@map("lease_milestones")
}

model MileageReading {
  id                  String        @id
  leaseId             String        @map("lease_id")
  recordedAt          DateTime      @map("recorded_at") @db.Timestamp(3)
  odometerKm          Int           @map("odometer_km")
  source              MileageSource
  recordedByUserId    String?       @map("recorded_by_user_id")
  evidenceBlobUrl     String?       @map("evidence_blob_url")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  lease       Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  recordedBy  User? @relation(fields: [recordedByUserId], references: [id])

  @@index([leaseId, recordedAt])
  @@map("mileage_readings")
}

// ─────────────────────────────────────────────────────────────────────
