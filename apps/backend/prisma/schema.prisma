generator client {
  // Python Prisma client. Same schema file as the Node backend so the database
  // stays the single source of truth during the migration window.
  // Docs: https://prisma-client-py.readthedocs.io/
  provider                   = "prisma-client-py"
  recursive_type_depth       = 5
  interface                  = "asyncio"
  partial_type_generator     = "prisma/partials.py"
  // Origin uses Decimal for currency fields (vehicle prices, payments, etc.).
  // Prisma Python requires opt-in for Decimal support.
  enable_experimental_decimal = "true"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl removed: railway.toml now sets DATABASE_URL=${DIRECT_URL:-$DATABASE_URL}
  // before every Prisma CLI call, so the CLI uses the direct (non-pooler) URL when
  // DIRECT_URL is set in Railway, and falls back to DATABASE_URL otherwise.
  // Removing the env("DIRECT_URL") reference prevents "environment variable not found"
  // errors when DIRECT_URL is absent.
}

enum Brand {
  BYD
  HAVAL
  GWM
  CHERY
  OMODA
  GEELY
  JAECOO
  NIO
  VOYAH
  ZEEKR
}

enum FuelType {
  ELECTRIC
  HYBRID
  PETROL
  DIESEL
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum VehicleStatus {
  AVAILABLE
  LEASED
  MAINTENANCE
  RETIRED
}

enum Language {
  en
  ar
  zh
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentType {
  EMIRATES_ID
  DRIVING_LICENCE
  VISA
  PASSPORT
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum OcrStatus {
  NOT_STARTED       // default — uploaded, OCR not yet enqueued
  PROCESSING        // job enqueued, awaiting Azure DI response
  COMPLETED         // result stored in ocrFields
  FAILED            // 3 retries exhausted, falls back to manual review
  SKIPPED           // type doesn't support OCR (e.g. visa V1) or feature flag off
}

enum LeaseType {
  SHORT_TERM
  LONG_TERM
}

enum ServiceType {
  SELL
  RENT
  LEASE
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  CONVERTED
}

enum LeaseStatus {
  ACTIVE
  COMPLETED
  TERMINATED_EARLY
  RENEWED
}

enum PaymentType {
  DEPOSIT
  MONTHLY
  PENALTY
  REFUND
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  REFUNDED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum PaymentGateway {
  CHECKOUT_COM
  PAYTABS
  TABBY
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  SENT
  DELIVERED
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  FLEET_MANAGER
  SALES
  FINANCE
}

model VehicleCategory {
  id       String    @id @default(uuid())
  nameEn   String
  nameAr   String
  nameZh   String
  icon     String?
  vehicles Vehicle[]

  @@map("vehicle_categories")
}

model Vehicle {
  id                    String          @id @default(uuid())
  vin                   String          @unique
  plateNumber           String          @unique
  brand                 Brand
  model                 String
  year                  Int
  categoryId            String
  category              VehicleCategory @relation(fields: [categoryId], references: [id])
  fuelType              FuelType
  transmission          Transmission    @default(AUTOMATIC)
  colour                String
  seats                 Int
  status                VehicleStatus   @default(AVAILABLE)
  priceAed              Decimal?        @db.Decimal(12, 2)
  dailyRateAed          Decimal         @db.Decimal(10, 2)
  monthlyRateAed        Decimal         @db.Decimal(10, 2)
  leaseMonthlyAed       Decimal?        @db.Decimal(10, 2)
  downPaymentPct        Decimal         @db.Decimal(4, 2) @default(0.20)
  mileageLimitMonthly   Int             @default(3000)
  rtaRegistrationExpiry DateTime?
  insuranceExpiry       DateTime?
  lastServiceDate       DateTime?
  nextServiceDue        DateTime?
  notes                 String?
  images                VehicleImage[]
  bookings              Booking[]
  assignedBookings      Booking[]       @relation("AssignedVehicle")
  leases                Lease[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("vehicles")
}

model VehicleImage {
  id        String  @id @default(uuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([vehicleId])
  @@map("vehicle_images")
}

model Customer {
  id                String            @id @default(uuid())
  phone             String            @unique
  email             String?
  fullName          String
  nationality       String?
  preferredLanguage Language          @default(en)
  kycStatus           KycStatus         @default(PENDING)
  kycRejectionReason  String?
  whatsappOptIn       Boolean           @default(false)
  documents         Document[]
  bookings          Booking[]
  leases            Lease[]
  payments          Payment[]
  notifications     NotificationLog[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("customers")
}

model Document {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            DocumentType
  fileUrl         String
  expiryDate      DateTime?
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewer        AdminUser?     @relation(fields: [reviewedBy], references: [id])

  // ── KYC OCR (ADR-0002) ───────────────────────────────────────
  // Populated asynchronously after upload by origin_backend.kyc.ocr
  // when KYC_OCR_ENABLED feature flag is true. ocrFields holds the
  // curated structured extraction; the raw Azure DI response goes
  // to a separate blob in `kyc-ocr-raw/` for re-processing without
  // re-paying for OCR.
  ocrStatus         OcrStatus @default(NOT_STARTED)
  ocrProvider       String?   // e.g. "azure-doc-intel" — track for future provider swap
  ocrModel          String?   // e.g. "prebuilt-idDocument", "prebuilt-document"
  ocrFields         Json?     // structured extraction; shape varies by document type
  ocrConfidence     Float?    // overall doc-level confidence 0..1
  ocrRequestedAt    DateTime?
  ocrCompletedAt    DateTime?
  ocrFailureReason  String?

  // Audit: per-field deltas where the admin overrode OCR at approval.
  // Null when admin accepted OCR as-is.
  reviewerOverrides Json?

  @@index([customerId])
  @@index([ocrStatus])
  @@map("documents")
}

model Booking {
  id                String        @id @default(uuid())
  reference         String        @unique
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?      @relation(fields: [vehicleId], references: [id])
  assignedVehicleId String?
  assignedVehicle   Vehicle?      @relation("AssignedVehicle", fields: [assignedVehicleId], references: [id])
  leaseType         LeaseType
  serviceType       ServiceType   @default(RENT)
  startDate         DateTime
  endDate           DateTime
  durationDays      Int
  mileagePackage    Int
  addOns            Json          @default("{}")
  quotedTotalAed    Decimal       @db.Decimal(10, 2)
  vatAmountAed      Decimal       @db.Decimal(10, 2)
  grandTotalAed     Decimal       @db.Decimal(10, 2)
  depositAmountAed  Decimal       @db.Decimal(10, 2)
  depositPaid       Boolean       @default(false)
  status            BookingStatus @default(DRAFT)
  rejectionReason   String?
  pickupLocation    String?
  dropoffLocation   String?
  notes             String?
  lease             Lease?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@map("bookings")
}

model Lease {
  id                  String      @id @default(uuid())
  reference           String      @unique
  bookingId           String      @unique
  booking             Booking     @relation(fields: [bookingId], references: [id])
  customerId          String
  customer            Customer    @relation(fields: [customerId], references: [id])
  vehicleId           String
  vehicle             Vehicle     @relation(fields: [vehicleId], references: [id])
  startDate           DateTime
  endDate             DateTime
  serviceType         ServiceType @default(RENT)
  monthlyRateAed      Decimal     @db.Decimal(10, 2)
  vatRate             Decimal     @db.Decimal(4, 4) @default(0.0500)
  mileageLimitMonthly Int
  downPaymentAed      Decimal?    @db.Decimal(10, 2)
  status              LeaseStatus @default(ACTIVE)
  renewalOfId         String?
  renewalOf           Lease?      @relation("LeaseRenewal", fields: [renewalOfId], references: [id])
  renewals            Lease[]     @relation("LeaseRenewal")
  agreementPdfUrl     String?
  notes               String?
  payments            Payment[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([customerId])
  @@index([vehicleId])
  @@map("leases")
}

model Payment {
  id               String          @id @default(uuid())
  leaseId          String
  lease            Lease           @relation(fields: [leaseId], references: [id])
  customerId       String
  customer         Customer        @relation(fields: [customerId], references: [id])
  type             PaymentType
  amountAed        Decimal         @db.Decimal(10, 2)
  vatAmountAed     Decimal         @db.Decimal(10, 2)
  totalAed         Decimal         @db.Decimal(10, 2)
  dueDate          DateTime
  paidAt           DateTime?
  status           PaymentStatus   @default(PENDING)
  paymentMethod    PaymentMethod?
  gateway          PaymentGateway?
  gatewayReference String?
  invoicePdfUrl    String?
  createdAt        DateTime        @default(now())

  @@index([leaseId])
  @@index([customerId])
  @@map("payments")
}

model NotificationLog {
  id              String              @id @default(uuid())
  customerId      String
  customer        Customer            @relation(fields: [customerId], references: [id])
  channel         NotificationChannel
  template        String
  language        Language
  contentSnapshot String
  status          NotificationStatus  @default(SENT)
  sentAt          DateTime            @default(now())
  metadata        Json                @default("{}")

  @@index([customerId])
  @@map("notification_logs")
}

model AdminUser {
  id        String      @id @default(uuid())
  email     String      @unique
  password  String
  fullName  String
  role      AdminRole   @default(SALES)
  isActive  Boolean     @default(true)
  documents Document[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("admin_users")
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_inquiries")
}

/// OTP codes stored in the database instead of in-memory.
/// Codes are SHA-256 hashed; expired rows are cleaned up periodically.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
  @@map("otp_codes")
}
