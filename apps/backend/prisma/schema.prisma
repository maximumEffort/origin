// Origin backend schema — V1 genesis (rebuild 2026-05-02).
// Source of truth: docs/architecture/rebuild-erd.md (v0.5).
// Convention: snake_case tables/columns at the DB layer (@map / @@map),
// camelCase fields in the Prisma client.

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  interface            = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────

enum Language {
  en
  ar
  zh_CN @map("zh-CN")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES
  FLEET_MANAGER
}

enum ResidencyStatus {
  RESIDENT
  VISITOR
  GCC_RESIDENT
}

enum KycStatus {
  NOT_STARTED
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum KycDocStatus {
  UPLOADED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum OcrStatus {
  NOT_STARTED
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum OcrJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum OcrProvider {
  AZURE_DI
  LOCAL
}

enum OtpIdentityKind {
  EMAIL
  PHONE
}

enum OtpProvider {
  TWILIO_VERIFY
  LOCAL
}

enum SubjectKind {
  USER
  CUSTOMER
}

enum SessionRevokeReason {
  LOGOUT
  ROTATED
  REPLAY_DETECTED
  ADMIN_FORCE
  EXPIRED
}

enum PartyKind {
  INDIVIDUAL
  ORGANIZATION
}

enum OrganizationMemberRole {
  OWNER
  AUTHORIZED_SIGNATORY
  BOOKER
  ACCOUNTS_PAYABLE
}

enum Brand {
  NIO
  VOYAH
  ZEEKR
  BYD
  XPENG
  LI_AUTO
  DENZA
  MG
  HONGQI
}

enum BodyType {
  SUV
  SEDAN
  MPV
  COUPE
  CROSSOVER
  WAGON
}

enum Powertrain {
  EV
  PHEV
  HYBRID
  ICE
}

enum Transmission {
  AUTOMATIC
  MANUAL
  SINGLE_SPEED
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  RENTED
  MAINTENANCE
  RETIRED
}

enum HoldReason {
  BOOKING
  LEASE
  MAINTENANCE
  MANUAL_BLOCK
}

enum HoldReferenceKind {
  BOOKING
  LEASE
  MAINTENANCE
  NONE
}

enum RentalTier {
  SHORT_TERM
  LONG_TERM
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum LeaseType {
  SHORT_TERM
  LONG_TERM
}

enum LeaseStatus {
  ACTIVE
  COMPLETED
  TERMINATED
  DEFAULTED
}

enum MilestoneKind {
  START
  MONTHLY_BILLING
  RETURN_REMINDER
  RETURN_COMPLETED
  COMPLETION
}

enum MileageSource {
  PICKUP
  RETURN
  MID_LEASE
  SELF_REPORT
}

enum MaintenanceKind {
  SERVICE
  REPAIR
  INSPECTION
  TYRE_CHANGE
  BATTERY_CHECK
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  VOID
}

enum PaymentKind {
  DEPOSIT
  INVOICE_PAYMENT
  PENALTY
  MANUAL_CREDIT
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  CHECKOUT_COM
  PAYTABS
  CASH
  BANK_TRANSFER
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum CommunicationKind {
  EMAIL
  SMS
  WHATSAPP
}

enum CommunicationProvider {
  SENDGRID
  TWILIO_SMS
  TWILIO_WHATSAPP
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  BOUNCED
  SUPPRESSED
}

enum CommunicationPurpose {
  TRANSACTIONAL
  NOTIFICATION
  MARKETING
}

enum ConsentChannel {
  EMAIL
  SMS
  WHATSAPP
  PHONE_CALL
  POST
}

enum ConsentPurpose {
  MARKETING
  SERVICE_UPDATES
  RESEARCH
}

enum ConsentSource {
  REGISTRATION
  PROFILE_UPDATE
  ADMIN_IMPORT
  UNSUBSCRIBE_LINK
  INBOUND_REQUEST
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum ActorKind {
  USER
  CUSTOMER
  SYSTEM
}

// Forward-compat per CLAUDE.md. NO TABLE uses this column in V1.
enum ServiceType {
  RENT
  PURCHASE
  LEASE_TO_OWN
}

// ─────────────────────────────────────────────────────────────────────
// platform/countries
// ─────────────────────────────────────────────────────────────────────

model Country {
  id                     String   @id
  code                   String   @unique @db.Char(2)
  name                   String
  defaultCurrencyCode    String   @map("default_currency_code") @db.Char(3)
  vatRate                Float    @map("vat_rate")
  phoneRegex             String?  @map("phone_regex")
  defaultLanguage        Language @default(en) @map("default_language")
  enabledPaymentGateways Json     @default("[]") @map("enabled_payment_gateways")
  kycConfig              Json     @default("{}") @map("kyc_config")
  productFlags           Json     @default("{}") @map("product_flags")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy              String?  @map("created_by")
  updatedBy              String?  @map("updated_by")

  legalEntities       LegalEntity[]
  kycDocumentTypes    KycDocumentType[]
  users               User[]
  parties             Party[]
  customers           Customer[]
  organizations       Organization[]
  vehicles            Vehicle[]
  vehicleImages       VehicleImage[]
  availabilityHolds   VehicleAvailabilityHold[]
  rentalRateCards     RentalRateCard[]
  mileagePackages     MileagePackage[]
  addOns              AddOn[]
  promoCodes          PromoCode[]
  invoices            Invoice[]
  payments            Payment[]
  rentalAgreements    RentalAgreement[]
  termsDocuments      TermsDocument[]
  bookings            Booking[]
  leases              Lease[]
  kycDocuments        KycDocument[]
  communicationLogs   CommunicationLog[]
  outboxEvents        OutboxEvent[]
  auditLogs           AuditLog[]
  errorLogs           ErrorLog[]

  @@map("countries")
}

model LegalEntity {
  id                    String   @id
  countryId             String   @map("country_id")
  name                  String
  tradeLicenceNumber    String?  @map("trade_licence_number")
  taxRegistrationNumber String?  @map("tax_registration_number")
  address               String?
  city                  String?
  contactEmail          String?  @map("contact_email")
  contactPhone          String?  @map("contact_phone")
  invoicePrefix         String   @default("INV") @map("invoice_prefix")
  isDefault             Boolean  @default(false) @map("is_default")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy             String?  @map("created_by")
  updatedBy             String?  @map("updated_by")

  country  Country   @relation(fields: [countryId], references: [id])
  vehicles Vehicle[]
  invoices Invoice[]
  leases   Lease[]
  rentalAgreements RentalAgreement[]
  termsDocuments   TermsDocument[]

  @@index([countryId])
  @@map("legal_entities")
}

model KycDocumentType {
  id                 String   @id
  countryId          String   @map("country_id")
  code               String
  labelEn            String   @map("label_en")
  labelAr            String?  @map("label_ar")
  labelZh            String?  @map("label_zh")
  isRequired         Boolean  @default(false) @map("is_required")
  requiresExpiry     Boolean  @default(false) @map("requires_expiry")
  ocrProvider        String?  @map("ocr_provider")
  ocrModel           String?  @map("ocr_model")
  acceptedMimeTypes  Json     @default("[]") @map("accepted_mime_types")
  config             Json     @default("{}")
  sortOrder          Int      @default(0) @map("sort_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, code])
  @@index([countryId])
  @@map("kyc_document_types")
}

// ─────────────────────────────────────────────────────────────────────
// platform/identity
// ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  countryId     String    @map("country_id")
  email         String    @unique
  phoneE164     String?   @map("phone_e164")
  passwordHash  String    @map("password_hash") // argon2id, params self-encoded
  role          UserRole
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamp(3)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")

  country         Country @relation(fields: [countryId], references: [id])
  reviewedKycDocs KycDocument[]    @relation("KycDocReviewer")
  mileageReadings MileageReading[]

  @@map("users")
}

model Party {
  id                    String    @id
  countryId             String    @map("country_id")
  kind                  PartyKind
  displayName           String    @map("display_name")
  taxRegistrationNumber String?   @map("tax_registration_number")
  billingEmail          String?   @map("billing_email")
  billingAddress        String?   @map("billing_address")
  kycStatus             KycStatus @default(NOT_STARTED) @map("kyc_status")
  deletedAt             DateTime? @map("deleted_at") @db.Timestamp(3)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy             String?   @map("created_by")
  updatedBy             String?   @map("updated_by")

  country      Country       @relation(fields: [countryId], references: [id])
  customer     Customer?
  organization Organization?
  consents     Consent[]
  kycDocuments KycDocument[]
  bookings     Booking[]
  leases       Lease[]
  invoices     Invoice[]
  payments     Payment[]
  communicationLogs CommunicationLog[]

  @@index([countryId, kind, kycStatus])
  @@map("parties")
}

model Customer {
  id                  String          @id // shared with parties.id
  countryId           String          @map("country_id")
  email               String
  phoneE164           String          @map("phone_e164")
  fullName            String          @map("full_name")
  dob                 DateTime?       @db.Date
  nationalityIso2     String?         @map("nationality_iso2") @db.Char(2)
  residencyStatus     ResidencyStatus @map("residency_status")
  preferredLanguage   Language        @default(en) @map("preferred_language")
  marketingOptIn      Boolean         @default(false) @map("marketing_opt_in")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy           String?         @map("created_by")
  updatedBy           String?         @map("updated_by")

  party                Party @relation(fields: [id], references: [id], onDelete: Cascade)
  country              Country @relation(fields: [countryId], references: [id])
  organizationMembers  OrganizationMember[]
  signatoryFor         Organization[]       @relation("OrgPrimarySignatory")
  bookedBookings       Booking[]            @relation("BookingBookedBy")
  drivenLeases         Lease[]              @relation("LeasePrimaryDriver")

  @@unique([countryId, email])
  @@unique([countryId, phoneE164])
  @@map("customers")
}

model Organization {
  id                   String   @id // shared with parties.id
  countryId            String   @map("country_id")
  legalName            String   @map("legal_name")
  tradeLicenceNumber   String?  @map("trade_licence_number")
  industry             String?
  employeeCountBand    String?  @map("employee_count_band")
  paymentTermsDays     Int      @default(0) @map("payment_terms_days")
  primarySignatoryId   String?  @map("primary_signatory_id")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy            String?  @map("created_by")
  updatedBy            String?  @map("updated_by")

  party             Party    @relation(fields: [id], references: [id], onDelete: Cascade)
  country           Country  @relation(fields: [countryId], references: [id])
  primarySignatory  Customer? @relation("OrgPrimarySignatory", fields: [primarySignatoryId], references: [id])
  members           OrganizationMember[]

  @@unique([countryId, tradeLicenceNumber])
  @@map("organizations")
}

model OrganizationMember {
  id              String                 @id
  organizationId  String                 @map("organization_id")
  customerId      String                 @map("customer_id")
  role            OrganizationMemberRole
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?                @map("created_by")
  updatedBy       String?                @map("updated_by")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@unique([organizationId, customerId])
  @@index([customerId])
  @@map("organization_members")
}

model Consent {
  id              String         @id
  partyId         String         @map("party_id")
  channel         ConsentChannel
  purpose         ConsentPurpose
  grantedAt       DateTime?      @map("granted_at") @db.Timestamp(3)
  withdrawnAt     DateTime?      @map("withdrawn_at") @db.Timestamp(3)
  source          ConsentSource
  evidenceBlobUrl String?        @map("evidence_blob_url")
  ipAddress       String?        @map("ip_address")
  userAgent       String?        @map("user_agent")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?        @map("created_by")
  updatedBy       String?        @map("updated_by")

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId, channel, purpose])
  @@map("consents")
}

model OtpCode {
  id            String          @id
  identityKind  OtpIdentityKind @map("identity_kind")
  identity      String
  codeHash      String?         @map("code_hash") // null when provider = TWILIO_VERIFY
  provider      OtpProvider
  providerSid   String?         @map("provider_sid")
  expiresAt     DateTime        @map("expires_at") @db.Timestamp(3)
  attempts      Int             @default(0)
  consumedAt    DateTime?       @map("consumed_at") @db.Timestamp(3)
  ipAddress     String?         @map("ip_address")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  @@index([identity, expiresAt])
  @@map("otp_codes")
}

model Session {
  id                    String               @id
  subjectKind           SubjectKind          @map("subject_kind")
  subjectId             String               @map("subject_id")
  refreshTokenHash      String               @map("refresh_token_hash")
  rotatedFromSessionId  String?              @map("rotated_from_session_id")
  expiresAt             DateTime             @map("expires_at") @db.Timestamp(3)
  revokedAt             DateTime?            @map("revoked_at") @db.Timestamp(3)
  revokeReason          SessionRevokeReason? @map("revoke_reason")
  ipAddress             String?              @map("ip_address")
  userAgent             String?              @map("user_agent")
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)

  rotatedFrom Session?  @relation("SessionRotation", fields: [rotatedFromSessionId], references: [id])
  rotatedInto Session[] @relation("SessionRotation")

  @@index([subjectKind, subjectId])
  @@index([expiresAt])
  @@index([rotatedFromSessionId])
  @@map("sessions")
}

model KycDocument {
  id                 String       @id
  partyId            String       @map("party_id")
  countryId          String       @map("country_id")
  documentTypeCode   String       @map("document_type_code")
  blobUrl            String       @map("blob_url")
  mimeType           String       @map("mime_type")
  fileSizeBytes      BigInt       @map("file_size_bytes")
  expiresOn          DateTime?    @map("expires_on") @db.Date
  status             KycDocStatus @default(UPLOADED)
  ocrStatus          OcrStatus    @default(NOT_STARTED) @map("ocr_status")
  ocrPayload         Json         @default("{}") @map("ocr_payload")
  reviewerUserId     String?      @map("reviewer_user_id")
  reviewedAt         DateTime?    @map("reviewed_at") @db.Timestamp(3)
  rejectReason       String?      @map("reject_reason")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt          DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy          String?      @map("created_by")
  updatedBy          String?      @map("updated_by")

  party    Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  country  Country  @relation(fields: [countryId], references: [id])
  reviewer User?    @relation("KycDocReviewer", fields: [reviewerUserId], references: [id])
  ocrJobs  OcrJob[]

  @@index([partyId])
  @@index([status, countryId])
  @@map("kyc_documents")
}

// ─────────────────────────────────────────────────────────────────────
// platform/inventory
// ─────────────────────────────────────────────────────────────────────

model Vehicle {
  id              String        @id
  countryId       String        @map("country_id")
  legalEntityId   String        @map("legal_entity_id")
  brand           Brand
  model           String
  modelYear       Int           @map("model_year")
  bodyType        BodyType      @map("body_type")
  powertrain      Powertrain
  trim            String?
  plateNumber     String        @unique @map("plate_number")
  vin             String?       @unique
  color           String
  transmission    Transmission
  seats           Int
  status          VehicleStatus @default(AVAILABLE)
  odometerKm      Int           @default(0) @map("odometer_km")
  primaryImageUrl String?       @map("primary_image_url")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?       @map("created_by")
  updatedBy       String?       @map("updated_by")

  country     Country     @relation(fields: [countryId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  images      VehicleImage[]
  holds       VehicleAvailabilityHold[]
  rateCards   RentalRateCard[]
  bookings    Booking[]
  leases      Lease[]
  maintenance VehicleMaintenanceRecord[]

  @@index([countryId, status])
  @@index([brand, model])
  @@map("vehicles")
}

model VehicleImage {
  id        String   @id
  vehicleId String   @map("vehicle_id")
  countryId String   @map("country_id")
  blobUrl   String   @map("blob_url")
  sortOrder Int      @default(0) @map("sort_order")
  altEn     String?  @map("alt_en")
  altAr     String?  @map("alt_ar")
  altZh     String?  @map("alt_zh")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@index([vehicleId, sortOrder])
  @@map("vehicle_images")
}

model VehicleAvailabilityHold {
  id              String            @id
  vehicleId       String            @map("vehicle_id")
  countryId       String            @map("country_id")
  startAt         DateTime          @map("start_at") @db.Timestamp(3)
  endAt           DateTime          @map("end_at") @db.Timestamp(3)
  reason          HoldReason
  referenceKind   HoldReferenceKind @default(NONE) @map("reference_kind")
  referenceId     String?           @map("reference_id")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?           @map("created_by")
  updatedBy       String?           @map("updated_by")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@index([vehicleId, startAt, endAt])
  @@map("vehicle_availability_holds")
}

// ─────────────────────────────────────────────────────────────────────
// platform/pricing
// ─────────────────────────────────────────────────────────────────────

model RentalRateCard {
  id               String     @id
  countryId        String     @map("country_id")
  vehicleId        String?    @map("vehicle_id")
  tier             RentalTier
  dailyRateMinor   BigInt     @map("daily_rate_minor")
  monthlyRateMinor BigInt     @map("monthly_rate_minor")
  currencyCode     String     @map("currency_code") @db.Char(3)
  validFrom        DateTime   @map("valid_from") @db.Date
  validTo          DateTime?  @map("valid_to") @db.Date
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy        String?    @map("created_by")
  updatedBy        String?    @map("updated_by")

  country Country  @relation(fields: [countryId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([countryId, vehicleId, tier, validFrom])
  @@map("rental_rate_cards")
}

model MileagePackage {
  id                       String   @id
  countryId                String   @map("country_id")
  name                     String
  includedKmPerMonth       Int      @map("included_km_per_month")
  overageRatePerKmMinor    BigInt   @map("overage_rate_per_km_minor")
  currencyCode             String   @map("currency_code") @db.Char(3)
  sortOrder                Int      @default(0) @map("sort_order")
  isActive                 Boolean  @default(true) @map("is_active")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy                String?  @map("created_by")
  updatedBy                String?  @map("updated_by")

  country  Country   @relation(fields: [countryId], references: [id])
  bookings Booking[]

  @@index([countryId, isActive])
  @@map("mileage_packages")
}

model AddOn {
  id              String   @id
  countryId       String   @map("country_id")
  code            String
  labelEn         String   @map("label_en")
  labelAr         String?  @map("label_ar")
  labelZh         String?  @map("label_zh")
  kind            String
  priceMinor      BigInt   @map("price_minor")
  currencyCode    String   @map("currency_code") @db.Char(3)
  billingCadence  String   @map("billing_cadence") // ONCE, DAILY, MONTHLY
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, code])
  @@map("add_ons")
}

model PromoCode {
  id            String   @id
  countryId     String   @map("country_id")
  code          String
  discountKind  String   @map("discount_kind") // PERCENT, FIXED
  discountValue Float    @map("discount_value")
  validFrom     DateTime @map("valid_from") @db.Date
  validTo       DateTime? @map("valid_to") @db.Date
  maxUses       Int?     @map("max_uses")
  usedCount     Int      @default(0) @map("used_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, code])
  @@map("promo_codes")
}

// ─────────────────────────────────────────────────────────────────────
// platform/billing
// ─────────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id
  countryId      String        @map("country_id")
  legalEntityId  String        @map("legal_entity_id")
  partyId        String        @map("party_id")
  leaseId        String?       @map("lease_id")
  invoiceNumber  String        @unique @map("invoice_number")
  issuedAt       DateTime      @map("issued_at") @db.Timestamp(3)
  dueAt          DateTime      @map("due_at") @db.Timestamp(3)
  currencyCode   String        @map("currency_code") @db.Char(3)
  subtotalMinor  BigInt        @map("subtotal_minor")
  vatMinor       BigInt        @map("vat_minor")
  totalMinor     BigInt        @map("total_minor")
  status         InvoiceStatus @default(DRAFT)
  pdfBlobUrl     String?       @map("pdf_blob_url")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy      String?       @map("created_by")
  updatedBy      String?       @map("updated_by")

  country     Country     @relation(fields: [countryId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  party       Party       @relation(fields: [partyId], references: [id])
  lease       Lease?      @relation(fields: [leaseId], references: [id])
  lines       InvoiceLine[]
  payments    Payment[]

  @@index([partyId, status])
  @@index([legalEntityId, issuedAt])
  @@map("invoices")
}

model InvoiceLine {
  id             String  @id
  invoiceId      String  @map("invoice_id")
  descriptionEn  String  @map("description_en")
  descriptionAr  String? @map("description_ar")
  descriptionZh  String? @map("description_zh")
  quantity       Int
  unitAmountMinor BigInt @map("unit_amount_minor")
  lineTotalMinor BigInt  @map("line_total_minor")
  vatRate        Float   @map("vat_rate")
  taxCode        String? @map("tax_code")
  sortOrder      Int     @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

model Payment {
  id                  String          @id
  countryId           String          @map("country_id")
  partyId             String          @map("party_id")
  kind                PaymentKind
  invoiceId           String?         @map("invoice_id")
  leaseId             String?         @map("lease_id")
  provider            PaymentProvider
  providerPaymentId   String?         @map("provider_payment_id")
  amountMinor         BigInt          @map("amount_minor")
  currencyCode        String          @map("currency_code") @db.Char(3)
  status              PaymentStatus   @default(PENDING)
  capturedAt          DateTime?       @map("captured_at") @db.Timestamp(3)
  metadata            Json            @default("{}")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy           String?         @map("created_by")
  updatedBy           String?         @map("updated_by")

  country Country  @relation(fields: [countryId], references: [id])
  party   Party    @relation(fields: [partyId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  lease   Lease?   @relation(fields: [leaseId], references: [id])
  refunds Refund[]

  @@index([partyId, capturedAt])
  @@index([invoiceId])
  @@index([leaseId, kind])
  @@map("payments")
}

model PaymentIntent {
  id                String          @id
  paymentId         String?         @map("payment_id")
  provider          PaymentProvider
  providerIntentId  String          @unique @map("provider_intent_id")
  clientSecret      String?         @map("client_secret")
  amountMinor       BigInt          @map("amount_minor")
  currencyCode      String          @map("currency_code") @db.Char(3)
  status            String
  expiresAt         DateTime?       @map("expires_at") @db.Timestamp(3)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy         String?         @map("created_by")
  updatedBy         String?         @map("updated_by")

  @@map("payment_intents")
}

model Refund {
  id              String       @id
  paymentId       String       @map("payment_id")
  amountMinor     BigInt       @map("amount_minor")
  currencyCode    String       @map("currency_code") @db.Char(3)
  reason          String
  providerRefundId String?     @map("provider_refund_id")
  status          RefundStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy       String?      @map("created_by")
  updatedBy       String?      @map("updated_by")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("refunds")
}

// ─────────────────────────────────────────────────────────────────────
// platform/agreements
// ─────────────────────────────────────────────────────────────────────

model RentalAgreement {
  id              String   @id
  countryId       String   @map("country_id")
  legalEntityId   String   @map("legal_entity_id")
  leaseId         String   @unique @map("lease_id")
