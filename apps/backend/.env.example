# Origin backend — environment variables.
# Production values live in Azure Key Vault (kv-origin-prod-uaenorth) and are
# injected as env vars by the Container App. Local dev: copy to .env and fill.

# ── Core ────────────────────────────────────────────────────────────
APP_ENV=development                                # development | staging | production
APP_PORT=8080
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://origin:origin@localhost:5432/origin?schema=public

# ── Auth ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-16-chars-please
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ── CORS ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Azure Blob (KYC + vehicle imagery) ─────────────────────────────
# Required in production. Backend refuses to start if unset and APP_ENV=production.
AZURE_STORAGE_BLOB_ENDPOINT=
AZURE_STORAGE_KYC_CONTAINER=kyc-documents
AZURE_STORAGE_VEHICLE_CONTAINER=vehicle-imagery

# ── Azure Document Intelligence (KYC OCR) ──────────────────────────
AZURE_DOCINTEL_ENDPOINT=
KYC_OCR_ENABLED=false

# ── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Twilio ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── SendGrid ───────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@origin-auto.ae
