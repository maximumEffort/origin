# ============================================================
# Origin Car Leasing Platform — Backend Environment
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- App ----
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# ---- Database (Supabase / PostgreSQL) ----
# Supabase project: https://supabase.com/dashboard/project/cjpejonpmjuhwwymhrmk
#
# Use the POOLED URL for the running app (port 6543):
DATABASE_URL=postgresql://postgres.cjpejonpmjuhwwymhrmk:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Use the DIRECT URL for running migrations (port 5432):
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.cjpejonpmjuhwwymhrmk.supabase.co:5432/postgres

# ---- JWT Auth ----
# JWT_SECRET is required — the app will not start without it.
# Railway env vars must use these exact names: JWT_SECRET and JWT_EXPIRES_IN.
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- WhatsApp Business API ----
# Get from: Meta for Developers → Your App → WhatsApp → API Setup
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token

# ---- Checkout.com ----
# Get from: Checkout.com Dashboard → Developers → Keys
# Docs: https://www.checkout.com/docs
CHECKOUT_SECRET_KEY=sk_your_checkout_secret_key
CHECKOUT_PUBLIC_KEY=pk_your_checkout_public_key
CHECKOUT_WEBHOOK_SECRET=your_checkout_webhook_secret

# ---- Twilio (SMS / OTP) ----
# Get from: Twilio Console → Account Info
# Docs: https://www.twilio.com/docs/verify/api
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+971xxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- SendGrid (Email) ----
# Get from: SendGrid → Settings → API Keys
# Docs: https://docs.sendgrid.com/api-reference/mail-send
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@originleasing.ae
SENDGRID_FROM_NAME=Origin Car Leasing

# ---- Google Maps Platform ----
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---- Firebase (Push Notifications) ----
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# ---- Tabby (BNPL) ----
TABBY_API_KEY=your_tabby_secret_key
TABBY_MERCHANT_CODE=your_merchant_code
TABBY_PUBLIC_KEY=your_tabby_public_key

# ---- File Storage (Supabase Storage) ----
# Supabase includes built-in file storage — use for KYC document uploads
SUPABASE_URL=https://cjpejonpmjuhwwymhrmk.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,https://originleasing.ae
