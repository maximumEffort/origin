# Origin Backend (Python) — Environment Variables
# Copy to .env (gitignored) and fill in your values.

# ── App ──
APP_ENV=development           # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=3001
LOG_LEVEL=info

# ── Database (Postgres via Prisma Python) ──
# Pooled URL for the running app:
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/origin
# Direct URL for migrations (Prisma needs both):
DIRECT_URL=postgresql://postgres:CHANGEME@localhost:5432/origin

# ── JWT ──
# Required — app refuses to start without it.
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=30

# ── Twilio (OTP) ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SendGrid (Email) ──
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@origin-auto.ae
SENDGRID_FROM_NAME=Origin

# ── Stripe (Payments) ──
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,https://origin-auto.ae,https://admin.origin-auto.ae

# ── Admin defaults (only used during initial bootstrap) ──
ADMIN_EMAIL_DEFAULT=admin@origin-auto.ae

# ── Azure Blob Storage (KYC document uploads) ──
# Set this to upload KYC files to Azure Blob (production).
# When not set, files are saved locally to KYC_UPLOAD_DIR (dev only).
# AZURE_STORAGE_BLOB_ENDPOINT=https://stororiginproduaenorth.blob.core.windows.net/
KYC_UPLOAD_DIR=uploads
KYC_UPLOAD_MAX_SIZE_MB=10
