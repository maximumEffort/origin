# ============================================================
# Origin — Customer Site Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Backend API URL (Railway or self-hosted)
NEXT_PUBLIC_API_URL=https://car-leasing-business-production.up.railway.app/v1

# Site URL (for canonical URLs, sitemap, og:image)
NEXT_PUBLIC_SITE_URL=https://originleasing.net

# Stripe publishable key (test or live)
NEXT_PUBLIC_STRIPE_PK=pk_test_your_stripe_publishable_key

# Sentry DSN (optional — for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# WhatsApp number (without +)
NEXT_PUBLIC_WHATSAPP_NUMBER=971521439746
